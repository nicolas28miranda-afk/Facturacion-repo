# Copia a .env y edita:
#   cp .env.example .env

# --- Facturación (facturacion-back) ---
SPRING_PROFILES_ACTIVE=docker,oracle
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@//TU_HOST:1521/XE
SPRING_DATASOURCE_USERNAME=usuario_facturacion
SPRING_DATASOURCE_PASSWORD=clave_facturacion

# --- CDP (cib-ms-cdp) — puede ser otro usuario Oracle ---
CDP_SPRING_DATASOURCE_URL=jdbc:oracle:thin:@//TU_HOST:1521/XE
CDP_SPRING_DATASOURCE_USERNAME=CIBCDP
CDP_SPRING_DATASOURCE_PASSWORD=clave_cdp
